# Server port (internal, behind nginx)
PORT=3100

# Bearer token for auth — generate with: openssl rand -hex 32
CLEVERTREE_TTS_SECRET=changeme

# Path to piper binary
PIPER_BIN=/opt/piper/piper

# Path to voice models directory
PIPER_MODELS_DIR=/opt/piper/voices

# Comma-separated allowed origins
ALLOWED_ORIGINS=https://paradigm-threat.com,https://www.paradigm-threat.com,https://paradigm-threat-site.vercel.app,https://forgottenfuturebook.com,https://www.forgottenfuturebook.com,https://forgotten-future-site.vercel.app,http://localhost:3000,http://localhost:3001
